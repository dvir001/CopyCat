# ── Discord application ────────────────────────────────────────────────────────
# Found at https://discord.com/developers/applications → your app
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# Optional: Discord role ID whose members can run pk;admin commands
ADMIN_ROLE=

# ── Docker / GHCR ─────────────────────────────────────────────────────────────
# Your GitHub username or org — used to pull images from GHCR
# e.g. GHCR_OWNER=dvir001  →  ghcr.io/dvir001/copycat:latest
GHCR_OWNER=your_github_username_here
